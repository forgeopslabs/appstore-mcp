# App Store Connect API credentials for appstore-mcp.
# Copy to `.env` and fill in. Generate an API key in App Store Connect:
#   Users and Access -> Integrations -> App Store Connect API -> Team Keys.

# Your issuer ID (a UUID shown above the keys table). Required.
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# The Key ID of the API key you generated. Required.
ASC_KEY_ID=ABCD123456

# The private key. Provide EITHER the inline PEM contents (ASC_PRIVATE_KEY)
# OR a path to the downloaded .p8 file (ASC_PRIVATE_KEY_PATH). One is required.
#
# Inline (note: keep the BEGIN/END lines and newlines):
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Or by path:
ASC_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_ABCD123456.p8

# Optional: override the API origin (rarely needed).
# ASC_BASE_URL=https://api.appstoreconnect.apple.com

# Optional: log level/filter for tracing (written to stderr). Default: info.
# ASC_LOG=debug
